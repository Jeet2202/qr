# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
*.spec

# ─── Virtual Environment ─────────────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ─── Installed Packages ───────────────────────────────────────────────────────
site-packages/
packages/
*.whl
pip-wheel-metadata/

# ─── Environment Variables ───────────────────────────────────────────────────
.env
.env.local
.env.production

# ─── ML Models & Large Files ─────────────────────────────────────────────────
# Keep the folder structure but ignore the actual model files
models/*.pkl
models/*.joblib
models/*.pt
models/*.pth
models/*.onnx

# Keep the data folder structure but ignore generated datasets
data/*.pkl
data/*.csv
data/*.parquet

# ─── Uploaded / Temp Files ───────────────────────────────────────────────────
uploads/
tmp/
*.tmp

# ─── Datasets — PPT files are kept, labels.csv is kept ──────────────────────
# Uncomment below if you don't want to commit PPT training files:
# datasets/ppt_files/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── IDE & OS ─────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.user
.DS_Store
Thumbs.db
desktop.ini

# ─── Jupyter ─────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── HuggingFace model cache (can be huge) ───────────────────────────────────
# These are downloaded automatically at runtime — no need to commit
.cache/

